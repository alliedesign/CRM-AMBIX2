{
  "entities": {
    "Client": {
      "title": "Client",
      "description": "A business client managed by Ambix Allie.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "company": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "status": { "type": "string", "enum": ["Active", "Lead", "Inactive"] },
        "phone": { "type": "string" },
        "industry": { "type": "string" },
        "notes": { "type": "string" },
        "uid": { "type": "string" },
        "notificationsEnabled": { "type": "boolean" },
        "prefEmail": { "type": "string" },
        "prefPhone": { "type": "string" },
        "optInCompleted": { "type": "boolean" },
        "optInDate": { "type": "string" },
        "createdAt": { "type": "string" },
        "createdBy": { "type": "string" }
      },
      "required": ["name", "company", "email", "status", "createdAt", "createdBy"]
    },
    "Project": {
      "title": "Project",
      "description": "A project belonging to a client.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "status": { "type": "string" },
        "startDate": { "type": "string" },
        "estimatedEndDate": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string" },
        "createdBy": { "type": "string" }
      },
      "required": ["title", "type", "clientId", "status", "createdAt", "createdBy"]
    },
    "Task": {
      "title": "Task",
      "description": "A task within a project.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "projectId": { "type": "string" },
        "clientId": { "type": "string" },
        "status": { "type": "string" },
        "dueDate": { "type": "string" },
        "assignedTo": { "type": "string" },
        "createdAt": { "type": "string" },
        "createdBy": { "type": "string" }
      },
      "required": ["title", "projectId", "clientId", "status", "createdAt", "createdBy"]
    },
    "Lead": {
      "title": "Lead",
      "description": "A business lead for a client.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "source": { "type": "string" },
        "status": { "type": "string", "enum": ["New", "Purchased", "Interested", "Converted", "Lost", "Declined"] },
        "clientId": { "type": "string" },
        "type": { "type": "string" },
        "pricePaid": { "type": "number" },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "clientId", "status", "createdAt"]
    },
    "Campaign": {
      "title": "Campaign",
      "description": "An outreach campaign for a client.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "clientId": { "type": "string" },
        "type": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string" },
        "scheduledAt": { "type": "string" },
        "recipientCount": { "type": "number" },
        "createdAt": { "type": "string" }
      },
      "required": ["title", "clientId", "type", "content", "status", "createdAt"]
    },
    "ClientCustomer": {
      "title": "Client Customer",
      "description": "A customer belonging to one of Allie's clients.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "company": { "type": "string" },
        "clientId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "clientId", "createdAt"]
    },
    "ClientPayment": {
      "title": "Client Payment",
      "description": "A payment made by a customer to one of Allie's clients.",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "clientId": { "type": "string" },
        "projectId": { "type": "string" },
        "customerId": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["amount", "clientId", "projectId", "customerId", "status", "createdAt"]
    },
    "Payment": {
      "title": "Payment",
      "description": "A payment made to Ambix Allie by a client.",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "clientId": { "type": "string" },
        "projectId": { "type": "string" },
        "status": { "type": "string" },
        "date": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["amount", "clientId", "projectId", "status", "date", "createdAt"]
    },
    "ContractTemplate": {
      "title": "Contract Template",
      "description": "A template for contracts (e.g., NDA).",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["title", "content", "createdAt"]
    },
    "Call": {
      "title": "Call",
      "description": "A live video call record.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "active", "completed", "dismissed"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["clientId", "status", "createdBy", "createdAt"]
    },
    "PaymentPlan": {
      "title": "Payment Plan",
      "description": "A scheduled financial commitment for a client.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "totalAmount": { "type": "number" },
        "installments": { "type": "number" },
        "frequency": { "type": "string", "enum": ["weekly", "bi-weekly", "monthly", "custom"] },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Declined", "Completed"] },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["clientId", "title", "totalAmount", "installments", "frequency", "status", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Activity alerts for users and admins.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "actionUrl": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "title", "message", "type", "read", "createdAt"]
    }
  },
  "firestore": {
    "/clients": { "schema": "Client", "description": "Business clients list" },
    "/projects": { "schema": "Project", "description": "Project details" },
    "/tasks": { "schema": "Task", "description": "Project tasks" },
    "/leads": { "schema": "Lead", "description": "Client outreach leads" },
    "/campaigns": { "schema": "Campaign", "description": "Outreach campaigns" },
    "/clientCustomers": { "schema": "ClientCustomer", "description": "Customers of the client" },
    "/clientPayments": { "schema": "ClientPayment", "description": "Internal revenue for clients" },
    "/payments": { "schema": "Payment", "description": "Revenue for Ambix Allie" },
    "/contractTemplates": { "schema": "ContractTemplate", "description": "System-wide contract templates" },
    "/calls": { "schema": "Call", "description": "Video call signaling" },
    "/paymentPlans": { "schema": "PaymentPlan", "description": "Financial commitment schedules" },
    "/notifications": { "schema": "Notification", "description": "Activity stream alerts" }
  }
}
